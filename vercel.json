{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/translate",
      "dest": "/api/translate.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/$1"
    }
  ]
}
